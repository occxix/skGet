{
  "name": "skget",
  "version": "1.0.5",
  "description": "CLI skill management tool for developers - manage skills, knowledge base, and sync across devices",
  "type": "module",
  "bin": {
    "skget": "./bin/skget.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:beta": "node scripts/release.js beta"
  },
  "keywords": [
    "cli",
    "skill",
    "skills",
    "knowledge-base",
    "developer-tools",
    "code-snippets",
    "sync",
    "git",
    "snippet-manager",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/skget.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/skget/issues"
  },
  "homepage": "https://github.com/your-username/skget#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "@inquirer/prompts": "^7.0.0",
    "isomorphic-git": "^1.27.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "conf": "^13.0.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ]
}
